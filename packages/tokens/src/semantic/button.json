{
  "button": {
    "background": {
      "primary": { "$value": "{color.brand.primary}", "$type": "color" },
      "secondary": { "$value": "{color.brand.secondary}", "$type": "color" }
    },
    "padding": {
      "sm": { "$value": "{spacing.2}", "$type": "dimension" },
      "md": { "$value": "{spacing.4}", "$type": "dimension" }
    },
    "fontSize": {
      "$value": "{typography.fontSize.md}", "$type": "dimension"
    }
  }
}