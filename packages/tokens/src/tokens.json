{
  "core/color.json": {
    "color": {
      "brand": {
        "primary": {
          "$type": "color",
          "$value": "#0066FF"
        },
        "secondary": {
          "$type": "color",
          "$value": "#6B7280"
        }
      },
      "neutral": {
        "0": {
          "$type": "color",
          "$value": "#FFFFFF"
        },
        "100": {
          "$type": "color",
          "$value": "#F3F4F6"
        },
        "900": {
          "$type": "color",
          "$value": "#111827"
        }
      },
      "feedback": {
        "error": {
          "$type": "color",
          "$value": "#EF4444"
        },
        "success": {
          "$type": "color",
          "$value": "#22C55E"
        }
      }
    }
  },
  "core/spacing.json": {
    "spacing": {
      "1": {
        "$type": "dimension",
        "$value": "4px"
      },
      "2": {
        "$type": "dimension",
        "$value": "8px"
      },
      "3": {
        "$type": "dimension",
        "$value": "12px"
      },
      "4": {
        "$type": "dimension",
        "$value": "16px"
      },
      "6": {
        "$type": "dimension",
        "$value": "24px"
      },
      "8": {
        "$type": "dimension",
        "$value": "32px"
      }
    }
  },
  "core/typography.json": {
    "typography": {
      "fontFamily": {
        "base": {
          "$type": "fontFamily",
          "$value": "Inter, sans-serif"
        }
      },
      "fontSize": {
        "sm": {
          "$type": "dimension",
          "$value": "12px"
        },
        "md": {
          "$type": "dimension",
          "$value": "14px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "16px"
        },
        "xl": {
          "$type": "dimension",
          "$value": "20px"
        }
      },
      "fontWeight": {
        "regular": {
          "$type": "fontWeight",
          "$value": "400"
        },
        "medium": {
          "$type": "fontWeight",
          "$value": "500"
        },
        "semibold": {
          "$type": "fontWeight",
          "$value": "600"
        }
      },
      "lineHeight": {
        "tight": {
          "$type": "number",
          "$value": "1.2"
        },
        "normal": {
          "$type": "number",
          "$value": "1.5"
        }
      }
    }
  },
  "semantic/button.json": {
    "button": {
      "background": {
        "primary": {
          "$type": "color",
          "$value": "{color.brand.primary}"
        },
        "secondary": {
          "$type": "color",
          "$value": "{color.brand.secondary}"
        }
      },
      "padding": {
        "sm": {
          "$type": "dimension",
          "$value": "{spacing.2}"
        },
        "md": {
          "$type": "dimension",
          "$value": "{spacing.4}"
        }
      },
      "fontSize": {
        "$type": "dimension",
        "$value": "{typography.fontSize.md}"
      }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "core/color.json",
      "core/spacing.json",
      "core/typography.json",
      "semantic/button.json"
    ]
  }
}